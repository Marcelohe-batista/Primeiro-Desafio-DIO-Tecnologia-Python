# Sistema bancário que aceita 3 operações, depósito, saque e extrato. Deve aceitar apenas valores positivos,
# limite de 3 saques diários, máximo de R$ 500,00 por saque.
def menu ( ):
   menu = """
        Escolha a opção desejada:

        [1] Depositar
        [2] Sacar
        [3] Extrato
        [0] Sair
        => """
   return input(menu)
   
def depositar ( saldo, valor, extrato, /):
   if valor <= 0:
          print("Valor inválido, deve ser um valor maior que zero")
   else :
          saldo += valor
          extrato = extrato + f"Depósito: R$ {valor:.2f}\n"
          print (f"Depósito de R$ {valor:.2f} realisado com sucesso")

   return saldo, extrato
 
def sacar (* ,saldo, valor, extrato, limite,numero_saques,limite_saques):
      
      if valor> limite:
          print ("O limite máximo de saque é R$500,00")    
      elif valor> saldo:
          print("Saldo insuficiente")
      elif valor <= 0:
        print(f"Você digitou R${valor:.2f}. O valor deve ser maior que zero")    
      else:
          if numero_saques < limite_saques:
              saldo -= valor
              numero_saques += 1
              extrato = extrato + f"Saque: R$ {valor:.2f}\n"
              print (f"Saque de R$ {valor:.2f} realisado com sucesso")
              print (f"numero_saques = {numero_saques}")
              print (f"limite_saques = {limite_saques}")
          else:
              print("Limite de saques diários atingido")

      return saldo,extrato,numero_saques

def mostrar_extrato (saldo, /, *,extrato):
    print(extrato)
    print (f"Saldo disponível:R$ {saldo:.2f}")
    return extrato
   
