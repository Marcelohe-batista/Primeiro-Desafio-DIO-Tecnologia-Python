def main ( ):
   saldo = 0
   limite = 500
   extrato = ""
   numero_saques = 0
   limite_saques = 3

   while True:
      opcao = menu( )

      if opcao == "1": 
          print("depósito")
          d=float(input("Digite o valor que deseja depositar "))
          saldo, extrato = depositar (saldo,d,extrato)

      elif opcao == "2": 
          print("Saque")
          s=float(input("Digite o valor que deseja sacar "))
          saldo, extrato, numero_saques = sacar (valor=s, 
                        saldo=saldo ,
                        limite=limite, 
                        extrato=extrato, 
                        numero_saques=numero_saques,
                        limite_saques=limite_saques
                        )

      elif opcao == "3":
          print ("Extrato")
          mostrar_extrato (saldo, extrato=extrato)
         
      elif opcao == "0": 
         break
      
      else:
          print("Opção inválida") 
         
main ( )
